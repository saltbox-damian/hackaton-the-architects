PORT=8787

# 32+ character random string used to encrypt the session cookie
# generate with: openssl rand -base64 48
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Option A — SFDX CLI login (RECOMMENDED for dev/hackathon).
# No Connected App needed. Uses `sf org login web` under the hood.
# Just leave the SF_* vars below empty and click "Connect via SFDX CLI" in UI.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Option B — Connected App OAuth Web Server flow.
# Fill these only if you want the traditional OAuth path.
# ---------------------------------------------------------------------------
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://login.salesforce.com
SF_REDIRECT_URI=http://localhost:5173/api/sf/oauth/callback

# ---------------------------------------------------------------------------
# AI SDK — Vercel AI Gateway (default provider in the `ai` package)
# Get a key at https://vercel.com/dashboard/ai-gateway/api-keys
# The agent (lib/ai/agents/salesforce-agent.ts) uses anthropic/claude-sonnet-4.6.
# ---------------------------------------------------------------------------
AI_GATEWAY_API_KEY=
